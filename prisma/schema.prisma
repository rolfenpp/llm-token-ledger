generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TraceStatus {
  OK
  ERROR
  CANCELLED
}

enum SpanStatus {
  OK
  ERROR
  CANCELLED
}

enum SpanType {
  llm
  db
  tool
  http
  cache
  other
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
}

model Project {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  traces         Trace[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Trace {
  id           String      @id @default(uuid()) @db.Uuid
  traceId      String      @unique
  projectId    String      @db.Uuid
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  route        String
  status       TraceStatus @default(OK)
  startedAt    DateTime    @default(now())
  endedAt      DateTime?
  latencyMs    Int
  totalCostUsd Decimal     @default(0) @db.Decimal(18, 12)
  metadata     Json?
  spans        Span[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([projectId, startedAt])
  @@index([projectId, status])
}

model Span {
  id             String     @id @default(uuid()) @db.Uuid
  spanId         String
  traceId        String
  trace          Trace      @relation(fields: [traceId], references: [traceId], onDelete: Cascade)
  parentSpanId   String?
  spanType       SpanType
  name           String
  status         SpanStatus @default(OK)
  modelName      String?
  inputTokens    Int?
  outputTokens   Int?
  calculatedCost Decimal    @default(0) @db.Decimal(18, 12)
  latencyMs      Int
  startedAt      DateTime   @default(now())
  endedAt        DateTime?
  metadata       Json?
  createdAt      DateTime   @default(now())

  @@unique([traceId, spanId])
  @@index([traceId])
  @@index([spanType, modelName])
  @@index([startedAt])
}
